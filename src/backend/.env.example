AEGIS_APP_NAME=Aegis Backend
AEGIS_ENVIRONMENT=development
AEGIS_DEBUG=true
AEGIS_API_PREFIX=/api/v1
AEGIS_HOST=0.0.0.0
AEGIS_PORT=8000
AEGIS_ALLOWED_ORIGINS_RAW=http://localhost:5173,http://127.0.0.1:5173
AEGIS_PERSISTENCE_BACKEND=postgres
AEGIS_DATABASE_URL=postgresql://postgres:<local-password>@127.0.0.1:54322/postgres
# Supabase Cloud direct/Postgres example:
# AEGIS_DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
# Supabase Cloud pooler example:
# AEGIS_DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?sslmode=require
AEGIS_AUTH_ENABLED=false
AEGIS_AUTH_AUTHORITY=https://login.microsoftonline.com/<tenant-id>
AEGIS_AUTH_TENANT_ID=<tenant-id>
AEGIS_AUTH_CLIENT_ID=<application-client-id>
AEGIS_AUTH_ALLOWED_AUDIENCES_RAW=<application-client-id>,api://<application-client-id>
AEGIS_AUTH_ADMIN_ROLE_CODES_RAW=super_admin,org_admin,tech_admin
