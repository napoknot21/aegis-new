VITE_BACKEND_API_URL=http://localhost:8000/api/v1
# Used only when frontend auth is disabled for local development.
VITE_DEFAULT_ORG_ID=1

VITE_MSAL_CLIENT_ID=<application-client-id>
VITE_MSAL_AUTHORITY=https://login.microsoftonline.com/<tenant-id>
VITE_MSAL_REDIRECT_URI=/
VITE_MSAL_POST_LOGOUT_REDIRECT_URI=/
VITE_MSAL_SCOPES=api://<application-client-id>/.default
VITE_MSAL_CACHE_LOCATION=localStorage
VITE_MSAL_STORE_AUTH_STATE_IN_COOKIE=true
